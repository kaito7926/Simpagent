APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/simpagent/backend/backend.log
DEMO_SEED_ENABLED=true
DEMO_USER_EMAIL=demo.user@simpagent.test
DEMO_USER_PASSWORD=ThayDoiMatKhauDemoUser123
DEMO_ADMIN_EMAIL=demo.admin@simpagent.test
DEMO_ADMIN_PASSWORD=ThayDoiMatKhauDemoAdmin123
DATABASE_URL_FILE=/run/secrets/database_url
JWT_ISSUER=simpagent.local
JWT_AUDIENCE=simpagent-api
JWT_ACTIVE_KID=local-key
JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
REFRESH_HMAC_KEY_FILE=/run/secrets/refresh_hmac_key
CSRF_HMAC_KEY_FILE=/run/secrets/csrf_hmac_key
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_IDLE_TTL_SECONDS=604800
REFRESH_ABSOLUTE_TTL_SECONDS=2592000
ALLOWED_ORIGINS=http://localhost:8000
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
LLM_API_BASE=https://api.example.test/v1
LLM_API_KEY_FILE=/run/secrets/llm_api_key
LLM_MODEL=fake-model
GOOGLE_API_KEY_FILE=/run/secrets/google_api_key
SEARCH_MODEL=gemini-2.5-flash
PROVIDER_CHECK_TIMEOUT_SECONDS=2
