APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/simpagent/backend/backend.log
OTEL_TRACING_ENABLED=true
OTEL_SERVICE_NAME=simpagent-backend
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://tempo:4318/v1/traces
OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=5
OTEL_SAMPLE_RATIO=1.0
DEMO_SEED_ENABLED=true
DEMO_USER_EMAIL=demo.user@simpagent.test
DEMO_USER_PASSWORD=ThayDoiMatKhauDemoUser123
DEMO_ADMIN_EMAIL=demo.admin@simpagent.test
DEMO_ADMIN_PASSWORD=ThayDoiMatKhauDemoAdmin123
DATABASE_URL_FILE=/run/secrets/database_url
JWT_ISSUER=simpagent.local
JWT_AUDIENCE=simpagent-api
JWT_ACTIVE_KID=local-key
JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
REFRESH_HMAC_KEY_FILE=/run/secrets/refresh_hmac_key
CSRF_HMAC_KEY_FILE=/run/secrets/csrf_hmac_key
MESSAGE_ENCRYPTION_KEY_FILE=/run/secrets/message_encryption_key
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_IDLE_TTL_SECONDS=604800
REFRESH_ABSOLUTE_TTL_SECONDS=2592000
ALLOWED_ORIGINS=http://localhost:8000
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
LLM_API_BASE=https://api.example.test/v1
LLM_API_KEY=
LLM_API_KEY_FILE=/run/secrets/llm_api_key
LLM_MODEL=fake-model
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
GOOGLE_API_KEY=
GOOGLE_API_KEY_FILE=/run/secrets/google_api_key
SEARCH_MODEL=gemini-2.5-flash
GUARDRAIL_SAFETY_ENABLED_DEFAULT=true
AGENT_LOOP_MAX_ITERATIONS=2
PROVIDER_CHECK_TIMEOUT_SECONDS=2
PYTHON_SUPERVISOR_BASE_URL=http://sandbox:8080
PYTHON_SUPERVISOR_REQUEST_TIMEOUT_SECONDS=30
PYTHON_CAPABILITY_SECRET_FILE=/run/secrets/python_capability_secret
PYTHON_CAPABILITY_TTL_SECONDS=60
PYTHON_SESSION_TTL_SECONDS=900
PYTHON_ARTIFACT_STORAGE_DIR=/tmp/simpagent-python-artifacts

# Phase 5 small-production profile (copy to a real env file and replace values).
# Local Compose remains the primary demo path; Cloudflare is optional.
SIMPAGENT_APP_ENV=production
SIMPAGENT_DEBUG=false
SIMPAGENT_LOG_LEVEL=INFO
SIMPAGENT_OTEL_TRACING_ENABLED=false
SIMPAGENT_OTEL_SERVICE_NAME=simpagent-backend
SIMPAGENT_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://tempo:4318/v1/traces
SIMPAGENT_OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=5
SIMPAGENT_OTEL_SAMPLE_RATIO=1.0
SIMPAGENT_DATABASE_URL_FILE=/run/secrets/database_url
SIMPAGENT_ALLOWED_ORIGINS=https://app.example.test
SIMPAGENT_PUBLIC_APP_ORIGIN=https://app.example.test
SIMPAGENT_PUBLIC_API_ORIGIN=https://api.example.test
SIMPAGENT_TRUSTED_PROXY_CIDRS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22
SIMPAGENT_COOKIE_SECURE=true
SIMPAGENT_COOKIE_SAMESITE=strict
SIMPAGENT_DEMO_SEED_ENABLED=false
SIMPAGENT_JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
SIMPAGENT_JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
SIMPAGENT_REFRESH_HMAC_KEY_FILE=/run/secrets/refresh_hmac_key
SIMPAGENT_CSRF_HMAC_KEY_FILE=/run/secrets/csrf_hmac_key
SIMPAGENT_MESSAGE_ENCRYPTION_KEY_FILE=/run/secrets/message_encryption_key
SIMPAGENT_LLM_API_BASE=https://api.example.test/v1
SIMPAGENT_LLM_API_KEY_FILE=/run/secrets/llm_api_key
SIMPAGENT_GOOGLE_API_KEY_FILE=/run/secrets/google_api_key
SIMPAGENT_GOOGLE_CLIENT_ID=
SIMPAGENT_GOOGLE_CLIENT_SECRET=
SIMPAGENT_GOOGLE_REDIRECT_URI=https://api.example.test/api/auth/oauth/google/callback
SIMPAGENT_GITHUB_CLIENT_ID=
SIMPAGENT_GITHUB_CLIENT_SECRET=
SIMPAGENT_GITHUB_REDIRECT_URI=https://api.example.test/api/auth/oauth/github/callback
SIMPAGENT_PYTHON_CAPABILITY_SECRET_FILE=/run/secrets/python_capability_secret
SIMPAGENT_CLOUDFLARE_EDGE_OPTIONAL=true
SIMPAGENT_CLOUDFLARE_TUNNEL_HOSTNAME=api.example.test
SIMPAGENT_CLOUDFLARE_SOURCE_IP_HEADER=CF-Connecting-IP
