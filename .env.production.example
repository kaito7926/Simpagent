# Copy this file to .env.production before running the production override.
# Never commit real secrets. Put secret values in ./secrets-prod/ files instead.
# This file follows the repo's current host-env convention: keys are unprefixed.
# compose.prod.yaml maps them into SIMPAGENT_* variables inside the containers.

# Public HTTPS origins used by backend validation and Kong CORS.
ALLOWED_ORIGINS=https://app.example.test
PUBLIC_APP_ORIGIN=https://app.example.test
PUBLIC_API_ORIGIN=https://api.example.test

# Reverse proxy IP ranges that are allowed to supply X-Forwarded-For / X-Forwarded-Proto.
# Replace with the exact CIDRs for your edge, tunnel, ingress, or load balancer.
TRUSTED_PROXY_CIDRS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22

# Core production mode.
APP_ENV=production  
LOG_LEVEL=INFO
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
DEMO_SEED_ENABLED=false
PROVIDER_CHECK_TIMEOUT_SECONDS=2

# JWT / session identity.
JWT_ISSUER=simpagent.example.test
JWT_AUDIENCE=simpagent-api
JWT_ACTIVE_KID=prod-kid

# Secret file paths inside the containers.
DATABASE_URL_FILE=/run/secrets/database_url
JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
REFRESH_HMAC_KEY_FILE=/run/secrets/refresh_hmac_key
CSRF_HMAC_KEY_FILE=/run/secrets/csrf_hmac_key
LLM_API_KEY_FILE=/run/secrets/llm_api_key
GOOGLE_API_KEY_FILE=/run/secrets/google_api_key
PYTHON_CAPABILITY_SECRET_FILE=/run/secrets/python_capability_secret

# Optional direct env secrets. Leave blank when using the *_FILE variants above.
LLM_API_KEY=
GOOGLE_API_KEY=

# LLM / search provider settings.
LLM_API_BASE=https://api.example.test/v1
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
SEARCH_MODEL=gemini-2.5-flash
GUARDRAIL_SAFETY_ENABLED_DEFAULT=true

# OAuth providers. Fill only if the provider is enabled in your deployment.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.test/api/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.example.test/api/auth/oauth/github/callback

# Python sandbox integration.
PYTHON_SUPERVISOR_REQUEST_TIMEOUT_SECONDS=30
PYTHON_CAPABILITY_TTL_SECONDS=60
PYTHON_SESSION_TTL_SECONDS=900

# Optional Cloudflare/Tunnel hints documented in README.
CLOUDFLARE_EDGE_OPTIONAL=true
CLOUDFLARE_TUNNEL_HOSTNAME=api.example.test
CLOUDFLARE_SOURCE_IP_HEADER=CF-Connecting-IP
